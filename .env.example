# PostgreSQL — Railway auto-injects these when you add a Postgres plugin
# You can leave these blank; Railway sets them automatically via $DATABASE_URL
PG_DB_NAME=$PGDATABASE
PG_USER=$PGUSER
PG_PASSWORD=$PGPASSWORD
PG_HOST=$PGHOST
PG_PORT=$PGPORT

# Milvus — Use Zilliz Cloud (free tier) instead of self-hosted
# Sign up at: https://cloud.zilliz.com
MILVUS_HOST=your-zilliz-cluster-uri
MILVUS_PORT=19530
MILVUS_TOKEN=your-zilliz-api-token
MILVUS_USE_CLOUD=true

# AI Keys
OPENAI_API_KEY=your-openai-key
GROQ_API_KEY=your-groq-key
